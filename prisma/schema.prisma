// SQLite for local development. Point DATABASE_URL at Postgres in production —
// nothing else in this schema needs to change to make that switch.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// "candidate" (default) or "employer". Employers skip onboarding/case
// tracking entirely and get routed into /employer instead of /dashboard.
model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  passwordHash       String
  role               String   @default("candidate")
  country            String?
  citizenship        String?
  immigrationGoal    String?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())

  cases       ImmigrationCase[]
  profile     CandidateProfile?
  preferences Preferences?
  savedJobs   SavedJob[]
  documents   Document[]
  posts       CommunityPost[]
  replies     CommunityReply[]
  company     Company?
  applications Application[]
}

// A user's USCIS case. Onboarding creates the first one (skippable);
// My Journey and the dashboard read from here once it exists.
model ImmigrationCase {
  id             String   @id @default(cuid())
  userId         String
  visaType       String
  receiptNumber  String?
  priorityDate   DateTime?
  status         String   @default("Case Received")
  progress       Int      @default(10)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Career-side onboarding answers, read by My Career for job matching.
model CandidateProfile {
  id               String  @id @default(cuid())
  userId           String  @unique
  jobTitle         String?
  experienceYears  Int?
  desiredLocation  String?
  needsSponsorship Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Preferences {
  id                  String  @id @default(cuid())
  userId              String  @unique
  emailNotifications  Boolean @default(true)
  smsNotifications    Boolean @default(false)
  pushNotifications   Boolean @default(true)
  theme               String  @default("system")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id           String   @id @default(cuid())
  title        String
  company      String
  companyId    String?
  location     String
  salaryMin    Int
  salaryMax    Int
  sponsorship  Boolean  @default(false)
  remote       Boolean  @default(false)
  industry     String
  createdAt    DateTime @default(now())

  savedBy      SavedJob[]
  applications Application[]
  postedBy     Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
}

// One row per registered employer. `company` is a free-text snapshot on
// Job for seeded/legacy listings that predate a real Company relation.
model Company {
  id          String   @id @default(cuid())
  ownerId     String   @unique
  name        String
  industry    String?
  website     String?
  description String?
  createdAt   DateTime @default(now())

  owner User  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  jobs  Job[]
}

// Candidate applications to a job. Status drives the employer's
// applicant-review workflow (PATCH /applications/:id/status in the spec).
model Application {
  id          String   @id @default(cuid())
  jobId       String
  candidateId String
  status      String   @default("Applied")
  createdAt   DateTime @default(now())

  job       Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate User @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
}

// Join table for the "Save Job" action from the API spec (POST /jobs/:id/save).
model SavedJob {
  id     String @id @default(cuid())
  userId String
  jobId  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

// storagePath points into the local uploads/ dir for now. Swap for an S3
// key + signed URL in production — the DB row shape doesn't need to change.
model Document {
  id           String   @id @default(cuid())
  userId       String
  name         String
  category     String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  expiresAt    DateTime?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CommunityPost {
  id        String   @id @default(cuid())
  authorId  String
  title     String
  body      String
  group     String
  createdAt DateTime @default(now())

  author  User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies CommunityReply[]
}

model CommunityReply {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// actorId is nullable so a failed-login or pre-account event can still be
// logged; actorEmail is a denormalized snapshot so the row still reads
// sensibly if the actor account is later deleted.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     String
  targetType String?
  targetId   String?
  metadata   String?
  createdAt  DateTime @default(now())
}

model FeatureFlag {
  key         String   @id
  name        String
  description String
  enabled     Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}
